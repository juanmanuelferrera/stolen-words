---
---
<div class="drawer-overlay" id="settings-overlay"></div>
<aside class="drawer settings" id="settings-drawer" aria-label="Reader settings">
  <h3>Reader settings</h3>

  <div class="settings-row">
    <label>Font</label>
    <div class="opts" data-setting="font">
      <button data-value="serif">Serif</button>
      <button data-value="sans">Sans</button>
    </div>
  </div>

  <div class="settings-row">
    <label>Size</label>
    <div class="opts" data-setting="size">
      <button data-value="1">A−−</button>
      <button data-value="3">A−</button>
      <button data-value="4">A</button>
      <button data-value="5">A+</button>
      <button data-value="6">A++</button>
    </div>
  </div>

  <div class="settings-row">
    <label>Theme</label>
    <div class="opts" data-setting="theme">
      <button data-value="light">Light</button>
      <button data-value="sepia">Sepia</button>
      <button data-value="dark">Dark</button>
    </div>
  </div>

  <div class="settings-row">
    <label>Justify</label>
    <div class="opts" data-setting="justify">
      <button data-value="off">Off</button>
      <button data-value="on">On</button>
    </div>
  </div>
</aside>
